# --- Next.js / Vercel server env (NEVER commit real values) ---
# AWS credentials for IAM user `smart-vercel` (least-privilege)
AWS_REGION=il-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB tables (from CDK outputs)
TABLE_CUSTOMERS=smart-customers
TABLE_EMPLOYEES=smart-employees
TABLE_SETTINGS=smart-settings
TABLE_SAVED_MESSAGES=smart-saved-messages
TABLE_SMS_ACTIVITY_LOG=smart-sms-activity-log
TABLE_DEVICE_TOKENS=smart-device-tokens
TABLE_SMS_IDEMPOTENCY=smart-sms-idempotency
GSI_REVIEW_INDEX=review-index
GSI_PHONE_INDEX=phone-index

# SQS
SQS_QUEUE_URL=https://sqs.il-central-1.amazonaws.com/975050130305/sms-outbox

# Lambda / Scheduler
SEND_PUSH_FUNCTION_NAME=smart-sendPush
SEND_PUSH_LAMBDA_ARN=
WEEKLY_SMS_LAMBDA_ARN=
WEEKLY_PRECHECK_LAMBDA_ARN=
SCHEDULER_ROLE_ARN=
SCHEDULE_WEEKLY_SMS=smart-weekly-sms
SCHEDULE_WEEKLY_SMS_PRECHECK=smart-weekly-sms-precheck
SCHEDULE_WEEKLY_PUSH=smart-weekly-push

# EC2 API (balance / OTP) — HTTPS only
EC2_API_BASE=https://api.thevision.co.il
EC2_API_TOKEN=

# Session (iron-session) — 32+ random chars
SESSION_SECRET=

# reCAPTCHA (unsubscribe page)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

TIMEZONE=Asia/Jerusalem
